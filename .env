DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockdb
DB_USER=stock
DB_PASSWORD=stockpass
DATABASE_URL=postgresql+psycopg://stock:stockpass@localhost:5432/stockdb

SYMBOLS=AAPL,TSLA,MSFT,GLD,^GSPC,^IXIC,^DJI,^RUT
START_DATE=2015-01-01
SOURCE=yfinance
LOOKBACK_DAYS=7

TRAIN_START_DATE=2017-01-01
HORIZON_DAYS=5

# === Telegram ===
# ВАЖНО: отзови старый токен через @BotFather (/revoke) и положи новый сюда!
TELEGRAM_BOT_TOKEN=PUT_YOUR_NEW_TOKEN_HERE

# === Backtest defaults ===
BACKTEST_START_DATE=2022-01-01
BACKTEST_FEE_BPS=5
BACKTEST_PROB_THRESHOLD=0.55
BACKTEST_INITIAL_CAPITAL=100000

# === Models persistence ===
MODELS_DIR=artifacts/models
